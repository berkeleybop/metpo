# ==============================================================================
# METPO Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your API keys
# All scripts in this repository use this single .env file in the repository root

# BioPortal API Key
# Sign up for free at: https://bioportal.bioontology.org/accounts/new
BIOPORTAL_API_KEY=

# GitHub Token (optional, for GitHub API access)
GITHUB_TOKEN=

# ==============================================================================
# LLM Provider Configuration
# ==============================================================================

# For OpenAI:
OPENAI_API_KEY=
LITELLM_MODEL=openai:gpt-4o-mini

## For Anthropic:
#ANTHROPIC_API_KEY=
#LITELLM_MODEL=claude-3-sonnet-20240229

## For CBORG Proxy (LBL internal):
#CBORG_API_KEY=
#CBORG_API_BASE=https://api.cborg.lbl.gov

## For Custom Proxy (e.g., cborg.lbl.gov):
#ANTHROPIC_API_KEY=
#LITELLM_MODEL=claude-sonnet:latest
#LITELLM_API_BASE=https://api.cborg.lbl.gov/v1

# ==============================================================================
# Database Configuration
# ==============================================================================

# MongoDB connection (for BactoTraits/Madin workflows)
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=metpo

# ==============================================================================
# Development Settings
# ==============================================================================

# Enable debug output
DEBUG=false

# Default dry-run mode for destructive operations
DRY_RUN=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

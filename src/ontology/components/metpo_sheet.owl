AnnotationAssertion(Annotation(<http://purl.obolibrary.org/obo/IAO_0000119> <https://github.com/jmadin/bacteria_archaea_traits>) <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <https://w3id.org/metpo/1000844> "methanogenesis")
AnnotationAssertion(rdfs:label <https://w3id.org/metpo/1000844> "Methanogenesis")

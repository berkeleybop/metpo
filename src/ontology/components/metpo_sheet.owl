# Class: <https://w3id.org/metpo/1001101> (biosafety level)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/metpo/1001101> "A quality that categorizes biological agents according to their hazard level and required containment measures.")
AnnotationAssertion(Annotation(<http://purl.obolibrary.org/obo/IAO_0000119> <https://bacdive.dsmz.de/>) <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <https://w3id.org/metpo/1001101> "Safety information.risk assessment.biosafety level")
AnnotationAssertion(Annotation(<http://purl.obolibrary.org/obo/IAO_0000119> <https://metatraits.embl.de/>) <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <https://w3id.org/metpo/1001101> "biosafety level")
AnnotationAssertion(rdfs:label <https://w3id.org/metpo/1001101> "biosafety level")
SubClassOf(<https://w3id.org/metpo/1001101> <https://w3id.org/metpo/1000188>)

# Class: <https://w3id.org/metpo/1001102> (biosafety level 1)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/metpo/1001102> "A biosafety level that pose minimal potential hazard to laboratory workers and the environment, requiring only standard microbiological practices.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <https://w3id.org/metpo/1001102> "Anthea Guo")
AnnotationAssertion(Annotation(<http://purl.obolibrary.org/obo/IAO_0000119> <https://bacdive.dsmz.de/>) <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <https://w3id.org/metpo/1001102> "1")
AnnotationAssertion(rdfs:label <https://w3id.org/metpo/1001102> "biosafety level 1")
SubClassOf(<https://w3id.org/metpo/1001102> <https://w3id.org/metpo/1001101>)

# Class: <https://w3id.org/metpo/1001103> (biosafety level 2)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/metpo/1001103> "A biosafety level that pose moderate risk and are associated with human diseases present in the community.")
AnnotationAssertion(Annotation(<http://purl.obolibrary.org/obo/IAO_0000119> <https://bacdive.dsmz.de/>) <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <https://w3id.org/metpo/1001103> "2")
AnnotationAssertion(rdfs:label <https://w3id.org/metpo/1001103> "biosafety level 2")
SubClassOf(<https://w3id.org/metpo/1001103> <https://w3id.org/metpo/1001101>)

# Class: <https://w3id.org/metpo/1001104> (biosafety level 3)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/metpo/1001104> "A biosafety level that can cause serious or potentially lethal disease through inhalation or other routes, requiring specialized containment facilities with controlled access, directional airflow, and strict safety protocols.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <https://w3id.org/metpo/1001104> "Jed Dongjin Kim-Ozaeta")
AnnotationAssertion(Annotation(<http://purl.obolibrary.org/obo/IAO_0000119> <https://bacdive.dsmz.de/>) <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <https://w3id.org/metpo/1001104> "3")
AnnotationAssertion(Annotation(<http://purl.obolibrary.org/obo/IAO_0000119> <https://bacdive.dsmz.de/>) <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <https://w3id.org/metpo/1001104> "3**")
AnnotationAssertion(rdfs:label <https://w3id.org/metpo/1001104> "biosafety level 3")
SubClassOf(<https://w3id.org/metpo/1001104> <https://w3id.org/metpo/1001101>)

# Class: <https://w3id.org/metpo/1001105> (biosafety level 4)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/metpo/1001105> "A biosafety level that pose extreme risk of life-threatening disease through aerosol transmission with no available treatment.")
AnnotationAssertion(Annotation(<http://purl.obolibrary.org/obo/IAO_0000119> <https://bacdive.dsmz.de/>) <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <https://w3id.org/metpo/1001105> "4")
AnnotationAssertion(rdfs:label <https://w3id.org/metpo/1001105> "biosafety level 4")
SubClassOf(<https://w3id.org/metpo/1001105> <https://w3id.org/metpo/1001101>)

# Class: <https://w3id.org/metpo/1001106> (biosafety level 5)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <https://w3id.org/metpo/1001106> "A biosafety level that is proposed as a classification beyond BSL-4 for hypothetical biological agents requiring enhanced containment.")
AnnotationAssertion(Annotation(<http://purl.obolibrary.org/obo/IAO_0000119> <https://bacdive.dsmz.de/>) <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <https://w3id.org/metpo/1001106> "5")
AnnotationAssertion(rdfs:label <https://w3id.org/metpo/1001106> "biosafety level 5")
SubClassOf(<https://w3id.org/metpo/1001106> <https://w3id.org/metpo/1001101>)


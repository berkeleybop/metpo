AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <https://w3id.org/metpo/1000803> "Anthea Guo")
AnnotationAssertion(rdfs:label <https://w3id.org/metpo/1000803> "Oxidative phosphorylation")

    <!-- https://w3id.org/metpo/1001102 -->

    <owl:Class rdf:about="https://w3id.org/metpo/1001102">
        <rdfs:subClassOf rdf:resource="https://w3id.org/metpo/1001101"/>
        <obo:IAO_0000115>A biosafety level that pose minimal potential hazard to laboratory workers and the environment, requiring only standard microbiological practices.</obo:IAO_0000115>
        <obo:IAO_0000117>Anthea Guo</obo:IAO_0000117>
        <oboInOwl:hasRelatedSynonym>1</oboInOwl:hasRelatedSynonym>
        <rdfs:label>biosafety level 1</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/metpo/1001102"/>
        <owl:annotatedProperty rdf:resource="http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym"/>
        <owl:annotatedTarget>1</owl:annotatedTarget>
        <obo:IAO_0000119 rdf:resource="https://bacdive.dsmz.de/"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/metpo/1001103 -->

    <owl:Class rdf:about="https://w3id.org/metpo/1001103">
        <rdfs:subClassOf rdf:resource="https://w3id.org/metpo/1001101"/>
        <obo:IAO_0000115>A biosafety level that pose moderate risk and are associated with human diseases present in the community.</obo:IAO_0000115>
        <oboInOwl:hasRelatedSynonym>2</oboInOwl:hasRelatedSynonym>
        <rdfs:label>biosafety level 2</rdfs:label>
    </owl:Class>

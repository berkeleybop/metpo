        <owl:annotatedTarget>2</owl:annotatedTarget>
        <obo:IAO_0000119 rdf:resource="https://bacdive.dsmz.de/"/>
    </owl:Axiom>
    


    <!-- https://w3id.org/metpo/1001104 -->

    <owl:Class rdf:about="https://w3id.org/metpo/1001104">
        <rdfs:subClassOf rdf:resource="https://w3id.org/metpo/1001101"/>
        <obo:IAO_0000115>A biosafety level that can cause serious or potentially lethal disease through inhalation or other routes, requiring specialized containment facilities with controlled access, directional airflow, and strict safety protocols.</obo:IAO_0000115>
        <obo:IAO_0000117>Jed Dongjin Kim-Ozaeta</obo:IAO_0000117>
        <oboInOwl:hasRelatedSynonym>3</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>3**</oboInOwl:hasRelatedSynonym>
        <rdfs:label>biosafety level 3</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/metpo/1001104"/>
        <owl:annotatedProperty rdf:resource="http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym"/>
        <owl:annotatedTarget>3</owl:annotatedTarget>
        <obo:IAO_0000119 rdf:resource="https://bacdive.dsmz.de/"/>
    </owl:Axiom>

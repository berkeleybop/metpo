    <!-- https://w3id.org/metpo/1007080 -->

    <owl:Class rdf:about="https://w3id.org/metpo/1007080">
        <rdfs:subClassOf rdf:resource="https://w3id.org/metpo/1000059"/>
        <obo:IAO_0000115>A biochemical test that detects catalase enzyme activity by exposing cells to hydrogen peroxide and observing for visible bubbling. The test outcome (positive or negative) is captured by its child classes; this class itself does not assert that the organism has catalase activity.</obo:IAO_0000115>
